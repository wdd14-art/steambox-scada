                            }
                            
                            if ($sb_12.sisa_detik_masak &gt; 0) {
                                $sb_12.sisa_detik_masak = $sb_12.sisa_detik_masak - 1;
                            }
                            
                            $sb_12.tampil_durasi_aktual = formatTime($sb_12.sisa_detik_masak);
