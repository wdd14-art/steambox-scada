                            $sb_18.sisa_detik_masak = $sb_18.sisa_detik_masak + ($sb_18.adjust_menit * 60);
                            if ($sb_18.sisa_detik_masak &lt; 0) {
                                $sb_18.sisa_detik_masak = 0;
                            }
