} else {
    if ($sb20._commStatus) { // CONNECTED
        if (!$sb_20.maintenance_mode) {
            var isSensorError_20 = ($sb20.temp &gt;= tempErrorLimit);
            
            if (Number($sb20.run_stop) === 1) { // STOPPED (Casting HMI Boolean to Number)
                $sb_20.status_pemanasan = false;
                $sb_20.status_pemasakan = false;
                $sb_20.flag_init_start = 0;
                
                // Jika operator memilih preheat atau mentransfer resep, tangki tidak kosong lagi
                if ($sb_20.mode_preheat || $sb_20.status_resep) {
                    $sb_20.status_kosong = false;
                }
                
                // Enforce status_kosong jika berada di kondisi standby default (dan preheat belum pernah jalan)
                if (!$sb_20.mode_preheat &amp;&amp; !$sb_20.status_resep &amp;&amp; $sb_20.target_menit === 0 &amp;&amp; $sb_20.sisa_detik_masak === 0 &amp;&amp; !$sb_20.status_selesai &amp;&amp; $sb_20.total_detik_pemanasan === 0) {
                    $sb_20.status_kosong = true;
                }
                
                if ($sb_20.status_kosong) {
                    $sb_20.status_banner = txtKosong;
                } else if ($sb_20.status_selesai) {
                    $sb_20.status_banner = txtSelesai;
                } else if (!$sb_20.status_kosong &amp;&amp; !$sb_20.status_selesai &amp;&amp; !$sb_20.mode_preheat &amp;&amp; !$sb_20.status_resep) {
                    // Kondisi selesai preheating: status_selesai tetap false, mode_preheat sudah dimatikan, status_kosong false, total_detik_pemanasan &gt; 0
                    $sb_20.status_banner = txtSelesaiPreheat;
                } else {
                    if ($sb_20.mode_preheat) {
                        if ($sb_20.total_detik_pemanasan === 0) {
                            $sb_20.status_banner = txtSiapPreheat;
                        } else {
                            $sb_20.status_banner = txtPreheatPaused;
                        }
                    } else {
                        if ($sb_20.status_resep &amp;&amp; $sb_20.sisa_detik_masak === 0) {
                            $sb_20.status_banner = txtStatusResep;
                        } else {
                            $sb_20.status_banner = txtPaused;
                        }
                    }
                }
            } else { // RUNNING
                
                // Kunci status selesai jika proses sudah kelar (mencegah fluktuasi suhu saat pendinginan sebelum PLC memproses STOP)
                if ($sb_20.status_selesai) {
                    $sb_20.status_pemanasan = false;
                    $sb_20.status_pemasakan = false;
                    $sb20.run_stop = 1; // Paksa kirim STOP ke Autonics
                } else {
                    $sb_20.status_kosong = false;
                    
                    if ($sb_20.mode_preheat) { // PRE-HEAT MODE (Hanya durasi pemanasan yang berjalan, jam mulai/masak/selesai tetap &quot;--:--:--&quot;)
                        $sb_20.status_pemanasan = true;
                        $sb_20.status_pemasakan = false;
                        $sb_20.status_banner = txtPreheat;
                        
                        if ($sb_20.flag_init_start === 0) {
                            $sb_20.tampil_jam_mulai = &quot;--:--:--&quot;;
                            $sb_20.tampil_jam_masak = &quot;--:--:--&quot;;
                            $sb_20.tampil_jam_selesai = &quot;--:--:--&quot;;
                            $sb_20.tampil_durasi_aktual = &quot;--&quot;;
                            $sb_20.durasi_aktual_up = &quot;--&quot;;
                            $sb_20.flag_init_start = 1;
                            $sb_20.total_detik_pemanasan = 0;
                            $sb_20.suhu_awal = $sb20.temp;
                        }
                        
                        $sb_20.total_detik_pemanasan = $sb_20.total_detik_pemanasan + 1;
                        $sb_20.tampil_pemanasan = formatTime($sb_20.total_detik_pemanasan);
                        
                        if ($sb20.temp &gt; 1000) {
                            $sb20.run_stop = 1; // STOP otomatis
                            $sb_20.status_pemanasan = false;
                            $sb_20.suhu_akhir = $sb20.temp;
                            $sb_20.flag_init_start = 0;
                            $sb_20.mode_preheat = false; // Balikkan mode_preheat otomatis ke false
                        }
                    } else { // COOKING MODE
                        if ($sb_20.flag_init_start === 0) {
                            $sb_20.tampil_jam_mulai = waktuSekarangString; // Catat jam mulai sekali
                            $sb_20.tampil_jam_masak = &quot;--:--:--&quot;;
                            $sb_20.tampil_jam_selesai = &quot;--:--:--&quot;;
                            $sb_20.flag_init_start = 1;
                            $sb_20.sisa_detik_masak = $sb_20.target_menit * 60;
                            $sb_20.total_detik_pemanasan = 0;
                            $sb_20.flag_init_masak = 0;
                            $sb_20.suhu_awal = $sb20.temp;
                        }
                        
                        if ($sb_20.adjust_menit !== 0) {
                            $sb_20.sisa_detik_masak = $sb_20.sisa_detik_masak + ($sb_20.adjust_menit * 60);
                            if ($sb_20.sisa_detik_masak &lt; 0) {
                                $sb_20.sisa_detik_masak = 0;
                            }
                            $sb_20.perubahan_waktu = $sb_20.perubahan_waktu + $sb_20.adjust_menit;
                            $sb_20.adjust_menit = 0;
                        }
                        
                        if ($sb20.temp &lt; 1000) { // Heating (&lt; 100 C)
                            $sb_20.status_pemanasan = true;
                            $sb_20.status_pemasakan = false;
                            $sb_20.status_banner = txtPemanasan; // Tunggu mendidih
                            $sb_20.total_detik_pemanasan = $sb_20.total_detik_pemanasan + 1;
                            $sb_20.tampil_pemanasan = formatTime($sb_20.total_detik_pemanasan);
                            
                            $sb_20.tampil_durasi_aktual = formatTime($sb_20.sisa_detik_masak);
                            var scale_up_20 = ($sb_20.target_menit * 60) - $sb_20.sisa_detik_masak;
                            var detik_up_heat = scale_up_20 &lt; 0 ? 0 : scale_up_20;
                            $sb_20.durasi_aktual_up = formatTime(detik_up_heat);
                            
                            // Jika sebelumnya sudah pernah mendidih (mengalami drop temp), jam selesai bertambah dan tetap tampil di monitor
                            if ($sb_20.flag_init_masak === 1) {
                                $sb_20.tampil_jam_selesai = getEstimasiSelesai(totalDetikSekarang, $sb_20.sisa_detik_masak);
                                runningRooms.push({
                                    name: 20, // Hanya nomor Steambox saja
                                    sisa: $sb_20.sisa_detik_masak,
                                    tampilSisa: $sb_20.tampil_durasi_aktual,
                                    tampilSelesai: $sb_20.tampil_jam_selesai
                                });
                            } else {
                                $sb_20.tampil_jam_selesai = &quot;--:--:--&quot;;
                            }
                        } else { // Boiling (&gt;= 100 C): Jam masak &amp; selesai dicatat, durasi aktual mulai hitung mundur
                            $sb_20.status_pemanasan = false;
                            $sb_20.status_pemasakan = true;
                            $sb_20.status_banner = txtPemasakan;
                            
                            if ($sb_20.flag_init_masak === 0) {
                                $sb_20.tampil_jam_masak = waktuSekarangString; // Catat jam masak sekali
                                $sb_20.flag_init_masak = 1;
                            }
                            
                            if ($sb_20.sisa_detik_masak &gt; 0) {
                                $sb_20.sisa_detik_masak = $sb_20.sisa_detik_masak - 1;
                            }
                            
                            $sb_20.tampil_durasi_aktual = formatTime($sb_20.sisa_detik_masak);
                            var scale_up_20 = ($sb_20.target_menit * 60) - $sb_20.sisa_detik_masak;
                            var detik_up_boil = scale_up_20 &lt; 0 ? 0 : scale_up_20;
                            $sb_20.durasi_aktual_up = formatTime(detik_up_boil);
                            
                            if ($sb_20.sisa_detik_masak &lt;= 0) {
                                $sb_20.sisa_detik_masak = 0;
                                $sb_20.tampil_durasi_aktual = formatTime(0);
                                $sb_20.durasi_aktual_up = formatTime($sb_20.target_menit * 60);
                                $sb_20.tampil_jam_selesai = getEstimasiSelesai(totalDetikSekarang, 0);
                                $sb_20.suhu_akhir = $sb20.temp;
                                $sb20.run_stop = 1; // STOP otomatis
                                $sb_20.status_pemasakan = false;
                                $sb_20.flag_init_start = 0;
                                $sb_20.flag_init_masak = 0;
                                $sb_20.status_selesai = true;
                            } else {
                                $sb_20.tampil_jam_selesai = getEstimasiSelesai(totalDetikSekarang, $sb_20.sisa_detik_masak);
                                runningRooms.push({
                                    name: 20, // Hanya nomor Steambox saja
                                    sisa: $sb_20.sisa_detik_masak,
                                    tampilSisa: $sb_20.tampil_durasi_aktual,
                                    tampilSelesai: $sb_20.tampil_jam_selesai
                                });
                            }
                        }
                    }
                }
            }
            
            // Alarm Sensor Error (Jika terjadi saat proses memasak aktif, ubah banner ke pesan kustom peringatan memasak)
            if (isSensorError_20) {
                $sb_20.sensor_error = true;
                if (Number($sb20.run_stop) === 0 &amp;&amp; $sb_20.flag_init_start === 1) {
                    $sb_20.status_banner = txtSensorErrorCooking;
                } else {
                    $sb_20.status_banner = txtSensorError;
                }
            } else {
                $sb_20.sensor_error = false;
            }
        } else { // MAINTENANCE MODE
            $sb_20.status_banner = txtMaintenance;
            $sb_20.sensor_error = false;
        }
    } else { // DISCONNECTED / OFFLINE
        $sb_20.status_banner = txtOffline;
        $sb_20.status_pemanasan = false;
        $sb_20.status_pemasakan = false;
        $sb_20.status_selesai = false;
        $sb_20.sensor_error = false;
    }
}

