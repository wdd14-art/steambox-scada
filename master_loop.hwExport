    $sb_14.status_pemanasan = false;
    $sb_14.status_pemasakan = false;
    $sb_14.status_selesai = false;
    $sb_14.sensor_error = false;
} else {
    if ($sb14._commStatus) { // CONNECTED
        if (!$sb_14.maintenance_mode) {
            var isSensorError_14 = ($sb14.temp &gt;= tempErrorLimit);
            
            if (Number($sb14.run_stop) === 1) { // STOPPED (Casting HMI Boolean to Number)
                $sb_14.status_pemanasan = false;
                $sb_14.status_pemasakan = false;
                $sb_14.flag_init_start = 0;
                
                // Jika operator memilih preheat atau mentransfer resep, tangki tidak kosong lagi
                if ($sb_14.mode_preheat || $sb_14.status_resep) {
                    $sb_14.status_kosong = false;
                }
                
                // Enforce status_kosong jika berada di kondisi standby default (dan preheat belum pernah jalan)
                if (!$sb_14.mode_preheat &amp;&amp; !$sb_14.status_resep &amp;&amp; $sb_14.target_menit === 0 &amp;&amp; $sb_14.sisa_detik_masak === 0 &amp;&amp; !$sb_14.status_selesai &amp;&amp; $sb_14.total_detik_pemanasan === 0) {
                    $sb_14.status_kosong = true;
                }
                
                if ($sb_14.status_kosong) {
                    $sb_14.status_banner = txtKosong;
                } else if ($sb_14.status_selesai) {
                    $sb_14.status_banner = txtSelesai;
                } else if (!$sb_14.status_kosong &amp;&amp; !$sb_14.status_selesai &amp;&amp; !$sb_14.mode_preheat &amp;&amp; !$sb_14.status_resep) {
                    // Kondisi selesai preheating: status_selesai tetap false, mode_preheat sudah dimatikan, status_kosong false, total_detik_pemanasan &gt; 0
                    $sb_14.status_banner = txtSelesaiPreheat;
                } else {
                    if ($sb_14.mode_preheat) {
                        if ($sb_14.total_detik_pemanasan === 0) {
                            $sb_14.status_banner = txtSiapPreheat;
                        } else {
                            $sb_14.status_banner = txtPreheatPaused;
                        }
                    } else {
                        if ($sb_14.status_resep &amp;&amp; $sb_14.sisa_detik_masak === 0) {
                            $sb_14.status_banner = txtStatusResep;
                        } else {
                            $sb_14.status_banner = txtPaused;
                        }
                    }
                }
            } else { // RUNNING
                
                // Kunci status selesai jika proses sudah kelar (mencegah fluktuasi suhu saat pendinginan sebelum PLC memproses STOP)
                if ($sb_14.status_selesai) {
                    $sb_14.status_pemanasan = false;
                    $sb_14.status_pemasakan = false;
                    $sb14.run_stop = 1; // Paksa kirim STOP ke Autonics
                } else {
                    $sb_14.status_kosong = false;
                    
                    if ($sb_14.mode_preheat) { // PRE-HEAT MODE (Hanya durasi pemanasan yang berjalan, jam mulai/masak/selesai tetap &quot;--:--:--&quot;)
                        $sb_14.status_pemanasan = true;
                        $sb_14.status_pemasakan = false;
                        $sb_14.status_banner = txtPreheat;
                        
                        if ($sb_14.flag_init_start === 0) {
                            $sb_14.tampil_jam_mulai = &quot;--:--:--&quot;;
                            $sb_14.tampil_jam_masak = &quot;--:--:--&quot;;
                            $sb_14.tampil_jam_selesai = &quot;--:--:--&quot;;
                            $sb_14.tampil_durasi_aktual = &quot;--&quot;;
                            $sb_14.durasi_aktual_up = &quot;--&quot;;
                            $sb_14.flag_init_start = 1;
                            $sb_14.total_detik_pemanasan = 0;
                            $sb_14.suhu_awal = $sb14.temp;
                        }
                        
                        $sb_14.total_detik_pemanasan = $sb_14.total_detik_pemanasan + 1;
                        $sb_14.tampil_pemanasan = formatTime($sb_14.total_detik_pemanasan);
                        
                        if ($sb14.temp &gt; 1000) {
                            $sb14.run_stop = 1; // STOP otomatis
                            $sb_14.status_pemanasan = false;
                            $sb_14.suhu_akhir = $sb14.temp;
                            $sb_14.flag_init_start = 0;
                            $sb_14.mode_preheat = false; // Balikkan mode_preheat otomatis ke false
                        }
                    } else { // COOKING MODE
                        if ($sb_14.flag_init_start === 0) {
                            $sb_14.tampil_jam_mulai = waktuSekarangString; // Catat jam mulai sekali
                            $sb_14.tampil_jam_masak = &quot;--:--:--&quot;;
                            $sb_14.tampil_jam_selesai = &quot;--:--:--&quot;;
                            $sb_14.flag_init_start = 1;
                            $sb_14.sisa_detik_masak = $sb_14.target_menit * 60;
                            $sb_14.total_detik_pemanasan = 0;
                            $sb_14.flag_init_masak = 0;
                            $sb_14.suhu_awal = $sb14.temp;
                        }
                        
                        if ($sb_14.adjust_menit !== 0) {
                            $sb_14.sisa_detik_masak = $sb_14.sisa_detik_masak + ($sb_14.adjust_menit * 60);
                            if ($sb_14.sisa_detik_masak &lt; 0) {
                                $sb_14.sisa_detik_masak = 0;
                            }
                            $sb_14.perubahan_waktu = $sb_14.perubahan_waktu + $sb_14.adjust_menit;
                            $sb_14.adjust_menit = 0;
                        }
                        
                        if ($sb14.temp &lt; 1000) { // Heating (&lt; 100 C)
                            $sb_14.status_pemanasan = true;
                            $sb_14.status_pemasakan = false;
                            $sb_14.status_banner = txtPemanasan; // Tunggu mendidih
                            $sb_14.total_detik_pemanasan = $sb_14.total_detik_pemanasan + 1;
                            $sb_14.tampil_pemanasan = formatTime($sb_14.total_detik_pemanasan);
                            
                            $sb_14.tampil_durasi_aktual = formatTime($sb_14.sisa_detik_masak);
                            var scale_up_14 = ($sb_14.target_menit * 60) - $sb_14.sisa_detik_masak;
                            var detik_up_heat = scale_up_14 &lt; 0 ? 0 : scale_up_14;
                            $sb_14.durasi_aktual_up = formatTime(detik_up_heat);
                            
                            // Jika sebelumnya sudah pernah mendidih (mengalami drop temp), jam selesai bertambah dan tetap tampil di monitor
                            if ($sb_14.flag_init_masak === 1) {
                                $sb_14.tampil_jam_selesai = getEstimasiSelesai(totalDetikSekarang, $sb_14.sisa_detik_masak);
                                runningRooms.push({
                                    name: 14, // Hanya nomor Steambox saja
                                    sisa: $sb_14.sisa_detik_masak,
                                    tampilSisa: $sb_14.tampil_durasi_aktual,
                                    tampilSelesai: $sb_14.tampil_jam_selesai
                                });
                            } else {
                                $sb_14.tampil_jam_selesai = &quot;--:--:--&quot;;
                            }
                        } else { // Boiling (&gt;= 100 C): Jam masak &amp; selesai dicatat, durasi aktual mulai hitung mundur
                            $sb_14.status_pemanasan = false;
                            $sb_14.status_pemasakan = true;
                            $sb_14.status_banner = txtPemasakan;
                            
                            if ($sb_14.flag_init_masak === 0) {
                                $sb_14.tampil_jam_masak = waktuSekarangString; // Catat jam masak sekali
                                $sb_14.flag_init_masak = 1;
                            }
                            
                            if ($sb_14.sisa_detik_masak &gt; 0) {
                                $sb_14.sisa_detik_masak = $sb_14.sisa_detik_masak - 1;
                            }
                            
                            $sb_14.tampil_durasi_aktual = formatTime($sb_14.sisa_detik_masak);
                            var scale_up_14 = ($sb_14.target_menit * 60) - $sb_14.sisa_detik_masak;
                            var detik_up_boil = scale_up_14 &lt; 0 ? 0 : scale_up_14;
                            $sb_14.durasi_aktual_up = formatTime(detik_up_boil);
                            
                            if ($sb_14.sisa_detik_masak &lt;= 0) {
                                $sb_14.sisa_detik_masak = 0;
                                $sb_14.tampil_durasi_aktual = formatTime(0);
                                $sb_14.durasi_aktual_up = formatTime($sb_14.target_menit * 60);
                                $sb_14.tampil_jam_selesai = getEstimasiSelesai(totalDetikSekarang, 0);
                                $sb_14.suhu_akhir = $sb14.temp;
                                $sb14.run_stop = 1; // STOP otomatis
                                $sb_14.status_pemasakan = false;
                                $sb_14.flag_init_start = 0;
                                $sb_14.flag_init_masak = 0;
                                $sb_14.status_selesai = true;
                            } else {
                                $sb_14.tampil_jam_selesai = getEstimasiSelesai(totalDetikSekarang, $sb_14.sisa_detik_masak);
                                runningRooms.push({
                                    name: 14, // Hanya nomor Steambox saja
                                    sisa: $sb_14.sisa_detik_masak,
                                    tampilSisa: $sb_14.tampil_durasi_aktual,
                                    tampilSelesai: $sb_14.tampil_jam_selesai
                                });
                            }
                        }
                    }
                }
            }
            
            // Alarm Sensor Error (Jika terjadi saat proses memasak aktif, ubah banner ke pesan kustom peringatan memasak)
            if (isSensorError_14) {
                $sb_14.sensor_error = true;
                if (Number($sb14.run_stop) === 0 &amp;&amp; $sb_14.flag_init_start === 1) {
                    $sb_14.status_banner = txtSensorErrorCooking;
                } else {
                    $sb_14.status_banner = txtSensorError;
                }
            } else {
                $sb_14.sensor_error = false;
            }
        } else { // MAINTENANCE MODE
            $sb_14.status_banner = txtMaintenance;
            $sb_14.sensor_error = false;
        }
    } else { // DISCONNECTED / OFFLINE
        $sb_14.status_banner = txtOffline;
        $sb_14.status_pemanasan = false;
        $sb_14.status_pemasakan = false;
        $sb_14.status_selesai = false;
        $sb_14.sensor_error = false;
    }
}

