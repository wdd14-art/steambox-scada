    $sb_28.target_menit = 0;
    $sb_28.adjust_menit = 0;
    $sb_28.tampil_jam_mulai = &quot;--:--:--&quot;;
    $sb_28.tampil_jam_masak = &quot;--:--:--&quot;;
    $sb_28.tampil_jam_selesai = &quot;--:--:--&quot;;
    $sb_28.tampil_durasi_aktual = &quot;--&quot;;
    $sb_28.durasi_aktual_up = &quot;--&quot;;
    $sb_28.tampil_pemanasan = &quot;--:--:--&quot;;
    $sb_28.suhu_awal = 0;
    $sb_28.suhu_akhir = 0;
    $sb_28.perubahan_waktu = 0;
    
    $recipe_kode.28 = &quot;&quot;;
    $recipe_nama.28 = &quot;--&quot;;
    $recipe_versi.28 = 0;
    $recipe_warna.28 = &quot;&quot;;
    $recipe_qty.28 = 0;
    $recipe_batch.28 = 0;
    $recipe_trolly.28 = &quot;&quot;;
    
    $sb_28.status_kosong = true;
    $sb_28.status_resep = false;
    $sb_28.mode_preheat = false;
    $sb_28.reset = false; // matikan trigger reset
}

if (!$sb28._commOperation) { // UNIT TIDAK DIPAKAI (Disabled)
    $sb_28.status_banner = txtDisable;
    $sb_28.status_pemanasan = false;
    $sb_28.status_pemasakan = false;
    $sb_28.status_selesai = false;
    $sb_28.sensor_error = false;
} else {
    if ($sb28._commStatus) { // CONNECTED
        if (!$sb_28.maintenance_mode) {
            var isSensorError_28 = ($sb28.temp &gt;= tempErrorLimit);
            
            if (Number($sb28.run_stop) === 1) { // STOPPED (Casting HMI Boolean to Number)
                $sb_28.status_pemanasan = false;
                $sb_28.status_pemasakan = false;
                $sb_28.flag_init_start = 0;
                
                // Jika operator memilih preheat atau mentransfer resep, tangki tidak kosong lagi
                if ($sb_28.mode_preheat || $sb_28.status_resep) {
                    $sb_28.status_kosong = false;
                }
                
                // Enforce status_kosong jika berada di kondisi standby default (dan preheat belum pernah jalan)
                if (!$sb_28.mode_preheat &amp;&amp; !$sb_28.status_resep &amp;&amp; $sb_28.target_menit === 0 &amp;&amp; $sb_28.sisa_detik_masak === 0 &amp;&amp; !$sb_28.status_selesai &amp;&amp; $sb_28.total_detik_pemanasan === 0) {
                    $sb_28.status_kosong = true;
                }
                
                if ($sb_28.status_kosong) {
                    $sb_28.status_banner = txtKosong;
                } else if ($sb_28.status_selesai) {
                    $sb_28.status_banner = txtSelesai;
                } else if (!$sb_28.status_kosong &amp;&amp; !$sb_28.status_selesai &amp;&amp; !$sb_28.mode_preheat &amp;&amp; !$sb_28.status_resep) {
                    // Kondisi selesai preheating: status_selesai tetap false, mode_preheat sudah dimatikan, status_kosong false, total_detik_pemanasan &gt; 0
                    $sb_28.status_banner = txtSelesaiPreheat;
                } else {
                    if ($sb_28.mode_preheat) {
                        if ($sb_28.total_detik_pemanasan === 0) {
                            $sb_28.status_banner = txtSiapPreheat;
                        } else {
                            $sb_28.status_banner = txtPreheatPaused;
                        }
                    } else {
                        if ($sb_28.status_resep &amp;&amp; $sb_28.sisa_detik_masak === 0) {
                            $sb_28.status_banner = txtStatusResep;
                        } else {
                            $sb_28.status_banner = txtPaused;
                        }
                    }
                }
            } else { // RUNNING
                
                // Kunci status selesai jika proses sudah kelar (mencegah fluktuasi suhu saat pendinginan sebelum PLC memproses STOP)
                if ($sb_28.status_selesai) {
                    $sb_28.status_pemanasan = false;
                    $sb_28.status_pemasakan = false;
                    $sb28.run_stop = 1; // Paksa kirim STOP ke Autonics
                } else {
                    $sb_28.status_kosong = false;
                    
                    if ($sb_28.mode_preheat) { // PRE-HEAT MODE (Hanya durasi pemanasan yang berjalan, jam mulai/masak/selesai tetap &quot;--:--:--&quot;)
                        $sb_28.status_pemanasan = true;
                        $sb_28.status_pemasakan = false;
                        $sb_28.status_banner = txtPreheat;
                        
                        if ($sb_28.flag_init_start === 0) {
                            $sb_28.tampil_jam_mulai = &quot;--:--:--&quot;;
                            $sb_28.tampil_jam_masak = &quot;--:--:--&quot;;
                            $sb_28.tampil_jam_selesai = &quot;--:--:--&quot;;
                            $sb_28.tampil_durasi_aktual = &quot;--&quot;;
                            $sb_28.durasi_aktual_up = &quot;--&quot;;
                            $sb_28.flag_init_start = 1;
                            $sb_28.total_detik_pemanasan = 0;
                            $sb_28.suhu_awal = $sb28.temp;
                        }
                        
                        $sb_28.total_detik_pemanasan = $sb_28.total_detik_pemanasan + 1;
                        $sb_28.tampil_pemanasan = formatTime($sb_28.total_detik_pemanasan);
                        
                        if ($sb28.temp &gt; 1000) {
                            $sb28.run_stop = 1; // STOP otomatis
                            $sb_28.status_pemanasan = false;
                            $sb_28.suhu_akhir = $sb28.temp;
                            $sb_28.flag_init_start = 0;
                            $sb_28.mode_preheat = false; // Balikkan mode_preheat otomatis ke false
                        }
                    } else { // COOKING MODE
                        if ($sb_28.flag_init_start === 0) {
                            $sb_28.tampil_jam_mulai = waktuSekarangString; // Catat jam mulai sekali
                            $sb_28.tampil_jam_masak = &quot;--:--:--&quot;;
                            $sb_28.tampil_jam_selesai = &quot;--:--:--&quot;;
                            $sb_28.flag_init_start = 1;
                            $sb_28.sisa_detik_masak = $sb_28.target_menit * 60;
                            $sb_28.total_detik_pemanasan = 0;
                            $sb_28.flag_init_masak = 0;
                            $sb_28.suhu_awal = $sb28.temp;
                        }
                        
                        if ($sb_28.adjust_menit !== 0) {
                            $sb_28.sisa_detik_masak = $sb_28.sisa_detik_masak + ($sb_28.adjust_menit * 60);
                            if ($sb_28.sisa_detik_masak &lt; 0) {
                                $sb_28.sisa_detik_masak = 0;
                            }
                            $sb_28.perubahan_waktu = $sb_28.perubahan_waktu + $sb_28.adjust_menit;
                            $sb_28.adjust_menit = 0;
                        }
                        
                        if ($sb28.temp &lt; 1000) { // Heating (&lt; 100 C)
                            $sb_28.status_pemanasan = true;
                            $sb_28.status_pemasakan = false;
                            $sb_28.status_banner = txtPemanasan; // Tunggu mendidih
                            $sb_28.total_detik_pemanasan = $sb_28.total_detik_pemanasan + 1;
                            $sb_28.tampil_pemanasan = formatTime($sb_28.total_detik_pemanasan);
                            
                            $sb_28.tampil_durasi_aktual = formatTime($sb_28.sisa_detik_masak);
                            var scale_up_28 = ($sb_28.target_menit * 60) - $sb_28.sisa_detik_masak;
                            var detik_up_heat = scale_up_28 &lt; 0 ? 0 : scale_up_28;
                            $sb_28.durasi_aktual_up = formatTime(detik_up_heat);
                            
                            // Jika sebelumnya sudah pernah mendidih (mengalami drop temp), jam selesai bertambah dan tetap tampil di monitor
                            if ($sb_28.flag_init_masak === 1) {
                                $sb_28.tampil_jam_selesai = getEstimasiSelesai(totalDetikSekarang, $sb_28.sisa_detik_masak);
                                runningRooms.push({
                                    name: 28, // Hanya nomor Steambox saja
                                    sisa: $sb_28.sisa_detik_masak,
                                    tampilSisa: $sb_28.tampil_durasi_aktual,
                                    tampilSelesai: $sb_28.tampil_jam_selesai
                                });
                            } else {
                                $sb_28.tampil_jam_selesai = &quot;--:--:--&quot;;
                            }
                        } else { // Boiling (&gt;= 100 C): Jam masak &amp; selesai dicatat, durasi aktual mulai hitung mundur
                            $sb_28.status_pemanasan = false;
                            $sb_28.status_pemasakan = true;
                            $sb_28.status_banner = txtPemasakan;
                            
                            if ($sb_28.flag_init_masak === 0) {
                                $sb_28.tampil_jam_masak = waktuSekarangString; // Catat jam masak sekali
                                $sb_28.flag_init_masak = 1;
                            }
                            
                            if ($sb_28.sisa_detik_masak &gt; 0) {
                                $sb_28.sisa_detik_masak = $sb_28.sisa_detik_masak - 1;
                            }
                            
                            $sb_28.tampil_durasi_aktual = formatTime($sb_28.sisa_detik_masak);
                            var scale_up_28 = ($sb_28.target_menit * 60) - $sb_28.sisa_detik_masak;
                            var detik_up_boil = scale_up_28 &lt; 0 ? 0 : scale_up_28;
                            $sb_28.durasi_aktual_up = formatTime(detik_up_boil);
                            
                            if ($sb_28.sisa_detik_masak &lt;= 0) {
                                $sb_28.sisa_detik_masak = 0;
                                $sb_28.tampil_durasi_aktual = formatTime(0);
                                $sb_28.durasi_aktual_up = formatTime($sb_28.target_menit * 60);
                                $sb_28.tampil_jam_selesai = getEstimasiSelesai(totalDetikSekarang, 0);
                                $sb_28.suhu_akhir = $sb28.temp;
                                $sb28.run_stop = 1; // STOP otomatis
                                $sb_28.status_pemasakan = false;
                                $sb_28.flag_init_start = 0;
                                $sb_28.flag_init_masak = 0;
                                $sb_28.status_selesai = true;
                            } else {
                                $sb_28.tampil_jam_selesai = getEstimasiSelesai(totalDetikSekarang, $sb_28.sisa_detik_masak);
                                runningRooms.push({
                                    name: 28, // Hanya nomor Steambox saja
                                    sisa: $sb_28.sisa_detik_masak,
                                    tampilSisa: $sb_28.tampil_durasi_aktual,
                                    tampilSelesai: $sb_28.tampil_jam_selesai
                                });
                            }
                        }
                    }
                }
            }
            
            // Alarm Sensor Error (Jika terjadi saat proses memasak aktif, ubah banner ke pesan kustom peringatan memasak)
            if (isSensorError_28) {
                $sb_28.sensor_error = true;
                if (Number($sb28.run_stop) === 0 &amp;&amp; $sb_28.flag_init_start === 1) {
                    $sb_28.status_banner = txtSensorErrorCooking;
                } else {
                    $sb_28.status_banner = txtSensorError;
                }
            } else {
                $sb_28.sensor_error = false;
            }
        } else { // MAINTENANCE MODE
            $sb_28.status_banner = txtMaintenance;
            $sb_28.sensor_error = false;
        }
    } else { // DISCONNECTED / OFFLINE
        $sb_28.status_banner = txtOffline;
        $sb_28.status_pemanasan = false;
        $sb_28.status_pemasakan = false;
        $sb_28.status_selesai = false;
        $sb_28.sensor_error = false;
    }
