    $sb_26.adjust_menit = 0;
    $sb_26.tampil_jam_mulai = &quot;--:--:--&quot;;
    $sb_26.tampil_jam_masak = &quot;--:--:--&quot;;
    $sb_26.tampil_jam_selesai = &quot;--:--:--&quot;;
    $sb_26.tampil_durasi_aktual = &quot;--&quot;;
    $sb_26.durasi_aktual_up = &quot;--&quot;;
    $sb_26.tampil_pemanasan = &quot;--:--:--&quot;;
    $sb_26.suhu_awal = 0;
    $sb_26.suhu_akhir = 0;
    $sb_26.perubahan_waktu = 0;
    
    $recipe_kode.26 = &quot;&quot;;
    $recipe_nama.26 = &quot;--&quot;;
    $recipe_versi.26 = 0;
    $recipe_warna.26 = &quot;&quot;;
    $recipe_qty.26 = 0;
    $recipe_batch.26 = 0;
    $recipe_trolly.26 = &quot;&quot;;
    
    $sb_26.status_kosong = true;
    $sb_26.status_resep = false;
    $sb_26.mode_preheat = false;
    $sb_26.reset = false; // matikan trigger reset
}

if (!$sb26._commOperation) { // UNIT TIDAK DIPAKAI (Disabled)
    $sb_26.status_banner = txtDisable;
    $sb_26.status_pemanasan = false;
    $sb_26.status_pemasakan = false;
    $sb_26.status_selesai = false;
    $sb_26.sensor_error = false;
} else {
    if ($sb26._commStatus) { // CONNECTED
        if (!$sb_26.maintenance_mode) {
            var isSensorError_26 = ($sb26.temp &gt;= tempErrorLimit);
            
            if (Number($sb26.run_stop) === 1) { // STOPPED (Casting HMI Boolean to Number)
                $sb_26.status_pemanasan = false;
                $sb_26.status_pemasakan = false;
                $sb_26.flag_init_start = 0;
                
                // Jika operator memilih preheat atau mentransfer resep, tangki tidak kosong lagi
                if ($sb_26.mode_preheat || $sb_26.status_resep) {
                    $sb_26.status_kosong = false;
                }
                
                // Enforce status_kosong jika berada di kondisi standby default (dan preheat belum pernah jalan)
                if (!$sb_26.mode_preheat &amp;&amp; !$sb_26.status_resep &amp;&amp; $sb_26.target_menit === 0 &amp;&amp; $sb_26.sisa_detik_masak === 0 &amp;&amp; !$sb_26.status_selesai &amp;&amp; $sb_26.total_detik_pemanasan === 0) {
                    $sb_26.status_kosong = true;
                }
                
                if ($sb_26.status_kosong) {
                    $sb_26.status_banner = txtKosong;
                } else if ($sb_26.status_selesai) {
                    $sb_26.status_banner = txtSelesai;
                } else if (!$sb_26.status_kosong &amp;&amp; !$sb_26.status_selesai &amp;&amp; !$sb_26.mode_preheat &amp;&amp; !$sb_26.status_resep) {
                    // Kondisi selesai preheating: status_selesai tetap false, mode_preheat sudah dimatikan, status_kosong false, total_detik_pemanasan &gt; 0
                    $sb_26.status_banner = txtSelesaiPreheat;
                } else {
                    if ($sb_26.mode_preheat) {
                        if ($sb_26.total_detik_pemanasan === 0) {
                            $sb_26.status_banner = txtSiapPreheat;
                        } else {
                            $sb_26.status_banner = txtPreheatPaused;
                        }
                    } else {
                        if ($sb_26.status_resep &amp;&amp; $sb_26.sisa_detik_masak === 0) {
                            $sb_26.status_banner = txtStatusResep;
                        } else {
                            $sb_26.status_banner = txtPaused;
                        }
                    }
                }
            } else { // RUNNING
                
                // Kunci status selesai jika proses sudah kelar (mencegah fluktuasi suhu saat pendinginan sebelum PLC memproses STOP)
                if ($sb_26.status_selesai) {
                    $sb_26.status_pemanasan = false;
                    $sb_26.status_pemasakan = false;
                    $sb26.run_stop = 1; // Paksa kirim STOP ke Autonics
                } else {
                    $sb_26.status_kosong = false;
                    
                    if ($sb_26.mode_preheat) { // PRE-HEAT MODE (Hanya durasi pemanasan yang berjalan, jam mulai/masak/selesai tetap &quot;--:--:--&quot;)
                        $sb_26.status_pemanasan = true;
                        $sb_26.status_pemasakan = false;
                        $sb_26.status_banner = txtPreheat;
                        
                        if ($sb_26.flag_init_start === 0) {
                            $sb_26.tampil_jam_mulai = &quot;--:--:--&quot;;
                            $sb_26.tampil_jam_masak = &quot;--:--:--&quot;;
                            $sb_26.tampil_jam_selesai = &quot;--:--:--&quot;;
                            $sb_26.tampil_durasi_aktual = &quot;--&quot;;
                            $sb_26.durasi_aktual_up = &quot;--&quot;;
                            $sb_26.flag_init_start = 1;
                            $sb_26.total_detik_pemanasan = 0;
                            $sb_26.suhu_awal = $sb26.temp;
                        }
                        
                        $sb_26.total_detik_pemanasan = $sb_26.total_detik_pemanasan + 1;
                        $sb_26.tampil_pemanasan = formatTime($sb_26.total_detik_pemanasan);
                        
                        if ($sb26.temp &gt; 1000) {
                            $sb26.run_stop = 1; // STOP otomatis
                            $sb_26.status_pemanasan = false;
                            $sb_26.suhu_akhir = $sb26.temp;
                            $sb_26.flag_init_start = 0;
                            $sb_26.mode_preheat = false; // Balikkan mode_preheat otomatis ke false
                        }
                    } else { // COOKING MODE
                        if ($sb_26.flag_init_start === 0) {
                            $sb_26.tampil_jam_mulai = waktuSekarangString; // Catat jam mulai sekali
                            $sb_26.tampil_jam_masak = &quot;--:--:--&quot;;
                            $sb_26.tampil_jam_selesai = &quot;--:--:--&quot;;
                            $sb_26.flag_init_start = 1;
                            $sb_26.sisa_detik_masak = $sb_26.target_menit * 60;
                            $sb_26.total_detik_pemanasan = 0;
                            $sb_26.flag_init_masak = 0;
                            $sb_26.suhu_awal = $sb26.temp;
                        }
                        
                        if ($sb_26.adjust_menit !== 0) {
                            $sb_26.sisa_detik_masak = $sb_26.sisa_detik_masak + ($sb_26.adjust_menit * 60);
                            if ($sb_26.sisa_detik_masak &lt; 0) {
                                $sb_26.sisa_detik_masak = 0;
                            }
                            $sb_26.perubahan_waktu = $sb_26.perubahan_waktu + $sb_26.adjust_menit;
                            $sb_26.adjust_menit = 0;
                        }
                        
                        if ($sb26.temp &lt; 1000) { // Heating (&lt; 100 C)
                            $sb_26.status_pemanasan = true;
                            $sb_26.status_pemasakan = false;
                            $sb_26.status_banner = txtPemanasan; // Tunggu mendidih
                            $sb_26.total_detik_pemanasan = $sb_26.total_detik_pemanasan + 1;
                            $sb_26.tampil_pemanasan = formatTime($sb_26.total_detik_pemanasan);
                            
                            $sb_26.tampil_durasi_aktual = formatTime($sb_26.sisa_detik_masak);
                            var scale_up_26 = ($sb_26.target_menit * 60) - $sb_26.sisa_detik_masak;
                            var detik_up_heat = scale_up_26 &lt; 0 ? 0 : scale_up_26;
                            $sb_26.durasi_aktual_up = formatTime(detik_up_heat);
                            
                            // Jika sebelumnya sudah pernah mendidih (mengalami drop temp), jam selesai bertambah dan tetap tampil di monitor
                            if ($sb_26.flag_init_masak === 1) {
                                $sb_26.tampil_jam_selesai = getEstimasiSelesai(totalDetikSekarang, $sb_26.sisa_detik_masak);
                                runningRooms.push({
                                    name: 26, // Hanya nomor Steambox saja
                                    sisa: $sb_26.sisa_detik_masak,
                                    tampilSisa: $sb_26.tampil_durasi_aktual,
                                    tampilSelesai: $sb_26.tampil_jam_selesai
                                });
                            } else {
                                $sb_26.tampil_jam_selesai = &quot;--:--:--&quot;;
                            }
                        } else { // Boiling (&gt;= 100 C): Jam masak &amp; selesai dicatat, durasi aktual mulai hitung mundur
                            $sb_26.status_pemanasan = false;
                            $sb_26.status_pemasakan = true;
                            $sb_26.status_banner = txtPemasakan;
                            
                            if ($sb_26.flag_init_masak === 0) {
                                $sb_26.tampil_jam_masak = waktuSekarangString; // Catat jam masak sekali
                                $sb_26.flag_init_masak = 1;
                            }
                            
                            if ($sb_26.sisa_detik_masak &gt; 0) {
                                $sb_26.sisa_detik_masak = $sb_26.sisa_detik_masak - 1;
                            }
                            
                            $sb_26.tampil_durasi_aktual = formatTime($sb_26.sisa_detik_masak);
                            var scale_up_26 = ($sb_26.target_menit * 60) - $sb_26.sisa_detik_masak;
                            var detik_up_boil = scale_up_26 &lt; 0 ? 0 : scale_up_26;
                            $sb_26.durasi_aktual_up = formatTime(detik_up_boil);
                            
                            if ($sb_26.sisa_detik_masak &lt;= 0) {
                                $sb_26.sisa_detik_masak = 0;
                                $sb_26.tampil_durasi_aktual = formatTime(0);
                                $sb_26.durasi_aktual_up = formatTime($sb_26.target_menit * 60);
                                $sb_26.tampil_jam_selesai = getEstimasiSelesai(totalDetikSekarang, 0);
                                $sb_26.suhu_akhir = $sb26.temp;
                                $sb26.run_stop = 1; // STOP otomatis
                                $sb_26.status_pemasakan = false;
                                $sb_26.flag_init_start = 0;
                                $sb_26.flag_init_masak = 0;
                                $sb_26.status_selesai = true;
                            } else {
                                $sb_26.tampil_jam_selesai = getEstimasiSelesai(totalDetikSekarang, $sb_26.sisa_detik_masak);
                                runningRooms.push({
                                    name: 26, // Hanya nomor Steambox saja
                                    sisa: $sb_26.sisa_detik_masak,
                                    tampilSisa: $sb_26.tampil_durasi_aktual,
                                    tampilSelesai: $sb_26.tampil_jam_selesai
                                });
                            }
                        }
                    }
                }
            }
            
            // Alarm Sensor Error (Jika terjadi saat proses memasak aktif, ubah banner ke pesan kustom peringatan memasak)
            if (isSensorError_26) {
                $sb_26.sensor_error = true;
                if (Number($sb26.run_stop) === 0 &amp;&amp; $sb_26.flag_init_start === 1) {
                    $sb_26.status_banner = txtSensorErrorCooking;
                } else {
                    $sb_26.status_banner = txtSensorError;
                }
            } else {
                $sb_26.sensor_error = false;
            }
        } else { // MAINTENANCE MODE
            $sb_26.status_banner = txtMaintenance;
            $sb_26.sensor_error = false;
        }
    } else { // DISCONNECTED / OFFLINE
        $sb_26.status_banner = txtOffline;
        $sb_26.status_pemanasan = false;
        $sb_26.status_pemasakan = false;
        $sb_26.status_selesai = false;
        $sb_26.sensor_error = false;
    }
