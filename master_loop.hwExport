                        }
                        
                        if ($sb_12.adjust_menit !== 0) {
                            $sb_12.sisa_detik_masak = $sb_12.sisa_detik_masak + ($sb_12.adjust_menit * 60);
                            if ($sb_12.sisa_detik_masak &lt; 0) {
                                $sb_12.sisa_detik_masak = 0;
                            }
                            $sb_12.perubahan_waktu = $sb_12.perubahan_waktu + $sb_12.adjust_menit;
