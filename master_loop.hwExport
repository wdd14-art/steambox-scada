                    $sb_16.status_pemanasan = false;
                    $sb_16.status_pemasakan = false;
                    $sb16.run_stop = 1; // Paksa kirim STOP ke Autonics
                } else {
                    $sb_16.status_kosong = false;
                    
                    if ($sb_16.mode_preheat) { // PRE-HEAT MODE (Hanya durasi pemanasan yang berjalan, jam mulai/masak/selesai tetap &quot;--:--:--&quot;)
                        $sb_16.status_pemanasan = true;
                        $sb_16.status_pemasakan = false;
                        $sb_16.status_banner = txtPreheat;
                        
                        if ($sb_16.flag_init_start === 0) {
                            $sb_16.tampil_jam_mulai = &quot;--:--:--&quot;;
                            $sb_16.tampil_jam_masak = &quot;--:--:--&quot;;
                            $sb_16.tampil_jam_selesai = &quot;--:--:--&quot;;
                            $sb_16.tampil_durasi_aktual = &quot;--&quot;;
                            $sb_16.durasi_aktual_up = &quot;--&quot;;
                            $sb_16.flag_init_start = 1;
                            $sb_16.total_detik_pemanasan = 0;
                            $sb_16.suhu_awal = $sb16.temp;
                        }
                        
                        $sb_16.total_detik_pemanasan = $sb_16.total_detik_pemanasan + 1;
                        $sb_16.tampil_pemanasan = formatTime($sb_16.total_detik_pemanasan);
                        
                        if ($sb16.temp &gt; 1000) {
                            $sb16.run_stop = 1; // STOP otomatis
                            $sb_16.status_pemanasan = false;
                            $sb_16.suhu_akhir = $sb16.temp;
                            $sb_16.flag_init_start = 0;
                            $sb_16.mode_preheat = false; // Balikkan mode_preheat otomatis ke false
                        }
                    } else { // COOKING MODE
                        if ($sb_16.flag_init_start === 0) {
                            $sb_16.tampil_jam_mulai = waktuSekarangString; // Catat jam mulai sekali
                            $sb_16.tampil_jam_masak = &quot;--:--:--&quot;;
                            $sb_16.tampil_jam_selesai = &quot;--:--:--&quot;;
                            $sb_16.flag_init_start = 1;
                            $sb_16.sisa_detik_masak = $sb_16.target_menit * 60;
                            $sb_16.total_detik_pemanasan = 0;
                            $sb_16.flag_init_masak = 0;
                            $sb_16.suhu_awal = $sb16.temp;
                        }
                        
                        if ($sb_16.adjust_menit !== 0) {
                            $sb_16.sisa_detik_masak = $sb_16.sisa_detik_masak + ($sb_16.adjust_menit * 60);
                            if ($sb_16.sisa_detik_masak &lt; 0) {
                                $sb_16.sisa_detik_masak = 0;
                            }
                            $sb_16.perubahan_waktu = $sb_16.perubahan_waktu + $sb_16.adjust_menit;
                            $sb_16.adjust_menit = 0;
                        }
                        
                        if ($sb16.temp &lt; 1000) { // Heating (&lt; 100 C)
                            $sb_16.status_pemanasan = true;
                            $sb_16.status_pemasakan = false;
